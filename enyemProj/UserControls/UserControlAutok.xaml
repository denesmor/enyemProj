<UserControl x:Class="enyemProj.UserControls.UserControlAutok"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:enyemProj.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="950" d:DesignWidth="1100">
    <UserControl.Resources>
        <ResourceDictionary Source="/Resources/ListItem.xaml"></ResourceDictionary>
    </UserControl.Resources>
    <DockPanel Background="Orange">
        <StackPanel Height="30" DockPanel.Dock="Top">
            <TextBlock
         FontWeight="ExtraBold"
         Foreground="Black"
         Text="PAPAS AUTO"
         TextAlignment="Center"
         FontSize="20"/>
        </StackPanel>
        <StackPanel
     Width="200"
     Background="DarkSlateGray"
     DockPanel.Dock="Left">
            <ListView Background="DarkSlateGray" BorderThickness="0">
                <ListViewItem
             x:Name="autoMENU"
             Content="Főoldal"
             MouseLeftButtonDown="autoMENU_MouseLeftButtonDown"
             Style="{StaticResource ResourceKey=ListItemStyle}" />
                <ListViewItem
             x:Name="felhasznaloMENU"
             Content="Felhasználó"
             MouseLeftButtonDown="felhasznaloMENU_MouseLeftButtonDown"
             Style="{StaticResource ResourceKey=ListItemStyle}" />
                <ListViewItem
             x:Name="vasarloMENU"
             Content="Vásárlás"
             MouseLeftButtonDown="vasarloMENU_MouseLeftButtonDown"
             Style="{StaticResource ResourceKey=ListItemStyle}" />
                <ListViewItem
             x:Name="rolunkMENU"
             Content="mink"
             MouseLeftButtonDown="rolunkMENU_MouseLeftButtonDown"
             Style="{StaticResource ResourceKey=ListItemStyle}" />
                <ListViewItem
             x:Name="kilepesMenu"
             Background="DarkRed"
             Content="Bezárás"
             Foreground="LightPink"
             MouseLeftButtonUp="kilepesMenu_MouseLeftButtonUp"
             Style="{StaticResource ResourceKey=ListItemStyle}" />
            </ListView>
        </StackPanel>
        <StackPanel x:Name="feladatPanel" DockPanel.Dock="Right" >
            <TextBlock FontSize="40">Autóink</TextBlock>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="200px"></RowDefinition>
                    <RowDefinition Height="200px"></RowDefinition>
                    <RowDefinition Height="200px"></RowDefinition>
                    <RowDefinition Height="200px"></RowDefinition>
                </Grid.RowDefinitions>
                <Image Source="/kepek/audir8.jpg" Width="200px" Grid.Column="0" Grid.Row="0" MouseLeftButtonDown="Image_MouseLeftButtonDown"></Image>
                <Image Source="/kepek/bmwi8.jpg" Width="200px" Grid.Column="1" Grid.Row="0" MouseLeftButtonDown="Image_MouseLeftButtonDown"></Image>
                <Image Source="/kepek/bugattidivo.jpg" Width="200px" Grid.Column="2" Grid.Row="0" MouseLeftButtonDown="Image_MouseLeftButtonDown"></Image>
                <Image Source="/kepek/ferrari488.jpg" Width="200px" Grid.Column="3" Grid.Row="0" MouseLeftButtonDown="Image_MouseLeftButtonDown"></Image>
                <Image Source="/kepek/koenigseggoneone.jpg" Width="200px" Grid.Column="0" Grid.Row="1" MouseLeftButtonDown="Image_MouseLeftButtonDown"></Image>
                <Image Source="/kepek/lambohuracan.jpeg" Width="200px" Grid.Column="1" Grid.Row="1" MouseLeftButtonDown="Image_MouseLeftButtonDown"></Image>
                <Image Source="/kepek/porsche911.jpg" Width="200px" Grid.Column="2" Grid.Row="1" MouseLeftButtonDown="Image_MouseLeftButtonDown"></Image>
               
            </Grid>

        </StackPanel>
    </DockPanel>
</UserControl>
