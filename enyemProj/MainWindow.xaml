<Window x:Class="enyemProj.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:enyemProj"
        mc:Ignorable="d"
        Title="MainWindow" 
        Height="950" 
        Width="1100" 
        WindowStartupLocation="CenterScreen" 
        WindowState="Maximized">
    <Window.Resources>
        <ResourceDictionary Source="/Resources/ListItem.xaml" />
    </Window.Resources>
    <DockPanel Background="Orange">
        <StackPanel Height="30" DockPanel.Dock="Top">
            <TextBlock
            FontWeight="ExtraBold"
            Foreground="Black"
            Text="PAPAS AUTO"
            TextAlignment="Center"
            FontSize="20"/>
        </StackPanel>
        <StackPanel
        Width="200"
        Background="DarkSlateGray"
        DockPanel.Dock="Left">
            <ListView Background="DarkSlateGray" BorderThickness="0">
                <ListViewItem
                x:Name="autoMENU"
                Content="Autók"
                MouseLeftButtonDown="autoMENU_MouseLeftButtonDown"
                Style="{StaticResource ResourceKey=ListItemStyle}" />
                <ListViewItem
                x:Name="felhasznaloMENU"
                Content="Felhasználó"
                MouseLeftButtonDown="felhasznaloMENU_MouseLeftButtonDown"
                Style="{StaticResource ResourceKey=ListItemStyle}" />
                <ListViewItem
                x:Name="vasarloMENU"
                Content="Vásárlás"
                MouseLeftButtonDown="vasarloMENU_MouseLeftButtonDown"
                Style="{StaticResource ResourceKey=ListItemStyle}" />
                <ListViewItem
                x:Name="rolunkMENU"
                Content="mink"
                MouseLeftButtonDown="rolunkMENU_MouseLeftButtonDown"
                Style="{StaticResource ResourceKey=ListItemStyle}" />
                <ListViewItem
                x:Name="kilepesMenu"
                Background="DarkRed"
                Content="Bezárás"
                Foreground="LightPink"
                MouseLeftButtonUp="kilepesMenu_MouseLeftButtonUp"
                Style="{StaticResource ResourceKey=ListItemStyle}" />
            </ListView>
        </StackPanel>
        <StackPanel x:Name="feladatPanel" DockPanel.Dock="Right" >
            <TextBlock FontSize="40">Márkák</TextBlock>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="200px"></RowDefinition>
                    <RowDefinition Height="200px"></RowDefinition>
                    <RowDefinition Height="200px"></RowDefinition>
                    <RowDefinition Height="200px"></RowDefinition>
                </Grid.RowDefinitions>
                <Image Source="/kepek/audi.png" Width="100px" Grid.Column="0" Grid.Row="0" MouseLeftButtonDown="Image_MouseLeftButtonDown"></Image>
                <Image Source="/kepek/bmw.png" Width="100px" Grid.Column="1" Grid.Row="0" MouseLeftButtonDown="Image_MouseLeftButtonDown"></Image>
                <Image Source="/kepek/merci.png" Width="100px" Grid.Column="2" Grid.Row="0" MouseLeftButtonDown="Image_MouseLeftButtonDown"></Image>
                <Image Source="/kepek/porshe.png" Width="100px" Grid.Column="3" Grid.Row="0" MouseLeftButtonDown="Image_MouseLeftButtonDown"></Image>
                <Image Source="/kepek/mclaren.png" Width="100px" Grid.Column="0" Grid.Row="1" MouseLeftButtonDown="Image_MouseLeftButtonDown"></Image>
                <Image Source="/kepek/bugatti.png" Width="100px" Grid.Column="1" Grid.Row="1" MouseLeftButtonDown="Image_MouseLeftButtonDown"></Image>
                <Image Source="/kepek/lambo.png" Width="100px" Grid.Column="2" Grid.Row="1" MouseLeftButtonDown="Image_MouseLeftButtonDown"></Image>
                <Image Source="/kepek/koenigsegg.png" Width="100px" Grid.Column="3" Grid.Row="1" MouseLeftButtonDown="Image_MouseLeftButtonDown"></Image>
                
            </Grid>
            
        </StackPanel>
    </DockPanel>
</Window>
