<Window x:Class="enyemProj.UserLogin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:enyemProj"
        mc:Ignorable="d"
        Title="UserLogin" Height="450" Width="300"
        FontSize="20"
        WindowStartupLocation="CenterScreen"
        Background="DarkSlateGray">
    <StackPanel Margin="20">
        <TextBlock
        HorizontalAlignment="Center"
        VerticalAlignment="Top"
        FontSize="25"
            Margin="0,0,0,20"
        FontWeight="Bold"
        Text="PAPAS AUTO LOGIN"
            Foreground="Orange"/>
        <Grid VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock
            Grid.Row="0"
            HorizontalAlignment="Left"
            Text="Felhasználónév:" 
                Foreground="Goldenrod"/>
            <TextBox
            x:Name="loginUserTxt"
            Grid.Row="1"
            Width="250"
            HorizontalAlignment="Left" 
                Background="DarkGray"/>
            <TextBlock
            Grid.Row="2"
            HorizontalAlignment="Left"
            Text="Jelszó:" 
                Foreground="Goldenrod"/>
            <PasswordBox
            x:Name="loginPasswordText"
            Grid.Row="3"
            Width="250"
            HorizontalAlignment="Left" 
                Background="DarkGray"/>
        </Grid>
        <TextBlock
        HorizontalAlignment="Right"
        FontSize="14"
        FontStyle="Italic"
        Foreground="Goldenrod"
        Text="Elfelejtett jelszó" />
        <Button
        x:Name="loginBtn"
        Width="250"
        Height="35"
        Margin="0,50,0,0"
        Background="Black"
        
        Content="Bejelentkezés"
        Foreground="Orange" />



    </StackPanel>
</Window>
